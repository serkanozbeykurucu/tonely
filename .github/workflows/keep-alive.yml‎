name: Keep Alive

on:
  schedule:
    - cron: '*/13 * * * *'
  workflow_dispatch:

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Ping
        run: |
          STATUS=$(curl -s -o /dev/null -w "%{http_code}" https://tonely-hmay.onrender.com/health/live)
          if [ "$STATUS" = "403" ]; then
            curl -f https://tonely-hmay.onrender.com/health/live
          elif [ "$STATUS" != "200" ]; then
            echo "Unexpected status: $STATUS"
            exit 1
          fi