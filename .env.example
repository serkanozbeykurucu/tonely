# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=TonelyDb
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET_KEY=your-min-32-char-secret-key-here
JWT_ISSUER=Tonely
JWT_AUDIENCE=Tonely
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=https://localhost:3000

# AI Provider — supported values: gemini, openai, claude, deepseek
AI_PROVIDER=gemini
AI_API_KEY=your_api_key_here,your_second_api_key_here
AI_MODEL=gemini-2.0-flash

# Plan Limits
PlanLimits__Plans__Free__MaxConversations=1
PlanLimits__Plans__Free__RateLimitPerMinute=5
PlanLimits__Plans__Pro__MaxConversations=-1
PlanLimits__Plans__Pro__RateLimitPerMinute=30

# App
ASPNETCORE_ENVIRONMENT=Development
NEXT_PUBLIC_API_URL=https://localhost:5042